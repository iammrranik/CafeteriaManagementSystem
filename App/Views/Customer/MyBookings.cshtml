@model IEnumerable<BLL.DTOs.MealBookingDTO>

@{
    ViewData["Title"] = "My Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h2>My Booking History</h2>
    <a href="/Customer/Index" class="btn btn-primary">Book Another Meal</a>
</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-info">@TempData["Msg"]</div>
}

@if (Model != null && Model.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Booking ID</th>
                <th>Menu Item ID</th>
                <th>Quantity</th>
                <th>Total Cost</th>
                <th>Scheduled Date</th>
                <th>Status</th>
                <th>Booking Time</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.MenuItemId</td>
                    <td>@item.OrderedQuantity</td>
                    <td>@item.TotalPrice TK</td>
                    <td>@item.BookingDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <span class="badge @(item.Status == "Booked" ? "bg-success" : "bg-danger")">@item.Status</span>
                    </td>
                    <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-warning">You do not have any active or past meal bookings yet.</div>
}
