@model IEnumerable<BLL.DTOs.MenuItemDTO>

@{
    ViewData["Title"] = "Cafeteria Menu";
}

<div class="row mb-4 bg-light p-4 rounded shadow-sm">
    <div class="col-md-8">
        <h2>Welcome to the Cafeteria!</h2>
        <p class="lead">Select your meals below and place your bookings. Daily bookings for today close at 9:00 AM.</p>
    </div>
    <div class="col-md-4 text-md-end text-start">
        <h5>Your Wallet Balance:</h5>
        <h3 class="@(ViewBag.WalletBalance < 100 ? "text-danger" : "text-success")">@ViewBag.WalletBalance TK</h3>
        @if (ViewBag.WalletBalance < 100)
        {
            <div class="badge bg-warning text-dark mb-2">Low Balance Warning</div>
        }
        <div>
            <a href="/Customer/Recharge" class="btn btn-outline-success btn-sm">Recharge Wallet</a>
        </div>
    </div>
</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-info">@TempData["Msg"]</div>
}

<div class="my-4">
    <h3 class="text-primary border-bottom pb-2">Today's Menu & Recommendations</h3>
    
    <table class="table table-bordered table-striped align-middle mt-3">
        <thead>
            <tr>
                <th>Food Item</th>
                <th>Category</th>
                <th>Price</th>
                <th>Stock Left</th>
                <th style="width: 320px;">Book Meal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <strong>@item.ItemName</strong>
                        @if (item.AvailableQuantity == 0)
                        {
                            <span class="badge bg-danger">Sold Out</span>
                        }
                    </td>
                    <td>@item.Category</td>
                    <td>@item.Price TK</td>
                    <td>@item.AvailableQuantity</td>
                    <td>
                        @if (item.AvailableQuantity > 0)
                        {
                            <form action="/Customer/BookMeal" method="post" class="d-flex gap-2">
                                <input type="hidden" name="MenuItemId" value="@item.Id" />
                                <input type="number" name="OrderedQuantity" value="1" min="1" max="@item.AvailableQuantity" class="form-control form-control-sm" style="width: 70px;" required />
                                <input type="date" name="BookingDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm" required />
                                <button type="submit" class="btn btn-primary btn-sm">Book</button>
                            </form>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-secondary w-100" disabled>Unavailable</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
