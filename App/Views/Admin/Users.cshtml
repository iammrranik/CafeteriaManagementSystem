@model IEnumerable<BLL.DTOs.UserDTO>

@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Users</h2>
    <a href="/Admin/CreateUser" class="btn btn-primary">Create New User</a>
</div>

@if (TempData["Msg"] != null)
{
    <div class="alert alert-info">@TempData["Msg"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>ID Card No</th>
            <th>Email</th>
            <th>Role ID</th>
            <th>Wallet Balance</th>
            <th>Status Quote</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.IdCardNo</td>
                <td>@item.Email</td>
                <td>@item.UserTypeId</td>
                <td>@item.WalletBalance TK</td>
                <td>@item.ProfileStatus</td>
                <td>
                    <div class="d-flex gap-2">
                        <a href="/Admin/EditUser/@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form action="/Admin/DeleteUser" method="post" onsubmit="return confirm('Are you sure you want to delete this user?');">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a href="/Admin/Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>
