@model IEnumerable<BLL.DTOs.SystemLogDTO>

@{
    ViewData["Title"] = "System Logs";
}

<h2>System Activity Logs</h2>
<hr />

@if (TempData["Msg"] != null)
{
    <div class="alert alert-info">@TempData["Msg"]</div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Log ID</th>
            <th>User ID</th>
            <th>Log Message</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.UserId</td>
                <td>@item.Message</td>
                <td>@item.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td>
                    <form action="/Admin/DeleteLog" method="post" onsubmit="return confirm('Are you sure you want to delete this log?');">
                        <input type="hidden" name="id" value="@item.Id" />
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div>
    <a href="/Admin/Dashboard" class="btn btn-secondary">Back to Dashboard</a>
</div>
