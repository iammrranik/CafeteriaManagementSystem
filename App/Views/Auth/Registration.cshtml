@model BLL.DTOs.UserDTO
@{
    ViewBag.Title = "Register";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center mb-4">Create Account</h2>
            
            @if (TempData["Msg"] != null)
            {
                <div class="alert alert-@TempData["Class"]">@TempData["Msg"]</div>
            }

            <form asp-action="Registration" asp-controller="Auth" method="post">
                <div class="mb-3">
                    <label>Full Name</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label>ID Card Number</label>
                    <input asp-for="IdCardNo" class="form-control" />
                    <span asp-validation-for="IdCardNo" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label>Password</label>
                    <input asp-for="Password" class="form-control" type="password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-success w-100">Complete Registration</button>
            </form>
        </div>
    </div>
</div>
